<script is:inline>
(function () {
  /* ── Particle canvas ─────────────────────────────────────── */
  var DARK_COLORS  = ['#0ea5e9','#22c55e','#a78bfa','#f59e0b','#60a5fa','#f87171'];
  var LIGHT_COLORS = ['#0ea5e9','#22c55e','#818cf8','#f59e0b','#38bdf8'];

  var canvas, ctx, particles, raf;

  function isDark() {
    return document.documentElement.classList.contains('dark');
  }
  function palette() { return isDark() ? DARK_COLORS : LIGHT_COLORS; }
  function moRange() { return isDark() ? [0.7, 1.0] : [0.4, 0.7]; }
  function rand(a, b) { return a + Math.random() * (b - a); }

  function makeParticle(w, h, fromBottom) {
    var mo = moRange(), pal = palette();
    return {
      x: rand(0, w),
      y: fromBottom ? h + rand(0, 20) : rand(0, h),
      r: rand(1.5, 4.5),
      speed: rand(0.4, 1.2),
      drift: rand(-0.3, 0.3),
      color: pal[Math.floor(Math.random() * pal.length)],
      isRing: Math.random() > 0.55,
      opacity: 0,
      maxOpacity: rand(mo[0], mo[1]),
    };
  }

  function initCanvas() {
    canvas = document.getElementById('hero-particles');
    if (!canvas) return;
    var panel = document.getElementById('hero-panel');
    canvas.width  = panel.offsetWidth;
    canvas.height = panel.offsetHeight;
    ctx = canvas.getContext('2d');
    particles = [];
    for (var i = 0; i < 38; i++) particles.push(makeParticle(canvas.width, canvas.height, false));
    if (raf) cancelAnimationFrame(raf);
    loop();
  }

  function loop() {
    raf = requestAnimationFrame(loop);
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    var w = canvas.width, h = canvas.height;

    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];
      p.y -= p.speed;
      p.x += p.drift;

      var fz = h * 0.15;
      if (p.y < fz) {
        p.opacity = (p.y / fz) * p.maxOpacity;
      } else if (p.y > h - fz) {
        p.opacity = ((h - p.y) / fz) * p.maxOpacity;
      } else {
        p.opacity = p.maxOpacity;
      }

      if (p.y + p.r < 0 || p.x < -20 || p.x > w + 20) {
        particles[i] = makeParticle(w, h, true);
        continue;
      }

      ctx.save();
      ctx.globalAlpha = Math.max(0, Math.min(1, p.opacity));
      ctx.strokeStyle = p.color;
      ctx.fillStyle   = p.color;
      ctx.beginPath();
      if (p.isRing) {
        ctx.lineWidth = 1;
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.stroke();
      } else {
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.restore();
    }
  }

  function recolorParticles() {
    if (!particles) return;
    var pal = palette(), mo = moRange();
    for (var i = 0; i < particles.length; i++) {
      particles[i].color = pal[Math.floor(Math.random() * pal.length)];
      particles[i].maxOpacity = rand(mo[0], mo[1]);
    }
  }

  /* ── Terminal animation ──────────────────────────────────── */
  var DELAYS = [300, 700, 1200, 1600, 2100, 2500, 2800, 3400];
  var termTimers = [];

  function runTerminal() {
    termTimers.forEach(clearTimeout);
    termTimers = [];
    var lines = document.querySelectorAll('#hero-terminal .term-line');
    lines.forEach(function (l) { l.style.opacity = '0'; });
    DELAYS.forEach(function (delay, i) {
      termTimers.push(setTimeout(function () {
        if (lines[i]) lines[i].style.opacity = '1';
      }, delay));
    });
  }

  /* ── Init on DOMContentLoaded ─────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {
    initCanvas();

    var panel = document.getElementById('hero-panel');
    if (panel && window.ResizeObserver) {
      new ResizeObserver(function () { initCanvas(); }).observe(panel);
    }

    runTerminal();

    /* Re-color particles when .dark toggles */
    new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        if (m.attributeName === 'class') recolorParticles();
      });
    }).observe(document.documentElement, { attributes: true });
  });
})();
</script>
