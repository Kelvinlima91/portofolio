  <!-- ═══════════════════════════════════════════
       STACK (id="stack")
  ═══════════════════════════════════════════ -->
  <section
    id="stack"
    class="py-16 fade-in"
    style="border-top: 1px solid var(--color-border);"
    x-data="stackSection()"
  >
    <div class="max-w-6xl mx-auto px-4">

      <!-- Section heading -->
      <div class="mb-5">
        <h2 class="flex items-center gap-2 text-xl font-semibold mb-1" style="color: var(--color-text-primary);">
          <i class="ti ti-package text-xl" style="color: var(--color-accent);"></i>
          <span x-text="t.section_stack_title">Minha Stack Tecnológica</span>
        </h2>
        <p class="text-sm" style="color: var(--color-text-muted);" x-text="t.section_stack_sub">Uma representação estruturada em JSON e explorável interativamente de todas as tecnologias que utilizo.</p>
      </div>

      <!-- Tech pills row -->
      <div class="flex flex-wrap gap-2 mb-5">
        {allTechItems.map((item) => (
          <button
            class="stack-pill"
            :class={`{ 'active': activeTech === '${item}' }`}
            @click={`activeTech = '${item}'`}
          >{item}</button>
        ))}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-5">

        <!-- Left (7 cols): JSON code viewer -->
        <div class="lg:col-span-7">
          <div
            class="rounded-lg overflow-hidden card-elevated"
            style="background-color: var(--color-card-bg); border: 1px solid var(--color-border);"
          >
            <!-- macOS title bar -->
            <div
              class="flex items-center justify-between px-4 py-2.5"
              style="border-bottom: 1px solid var(--color-border); background-color: var(--color-bg-panel);"
            >
              <div class="flex items-center gap-2">
                <i class="ti ti-file-code text-sm" style="color: var(--color-accent);"></i>
                <span class="font-mono text-xs" style="color: var(--color-text-muted);">stack.json</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="w-3 h-3 rounded-full" style="background: #ff5f57;"></span>
                <span class="w-3 h-3 rounded-full" style="background: #febc2e;"></span>
                <span class="w-3 h-3 rounded-full" style="background: #28c840;"></span>
              </div>
            </div>

            <!-- JSON body: compact single-line per category -->
            <div class="p-4 font-mono text-sm leading-loose overflow-x-auto">
              <span style="color: #e3b341;">{'{'}</span>
              {STACK.map((group, gi) => (
                <div class="pl-4">
                  <span style="color: #79c0ff;">&quot;{group.key}&quot;</span>
                  <span style="color: var(--color-text-muted);"> : [ </span>
                  {group.items.map((item, ii) => (
                    <span>
                      <span
                        class="stack-json-item"
                        :class={`{ 'active': activeTech === '${item}' }`}
                        @click={`activeTech = '${item}'`}
                      ><span style="color: #7ee787;">&quot;{item}&quot;</span></span>{ii < group.items.length - 1 ? <span style="color: var(--color-text-muted);">, </span> : null}
                    </span>
                  ))}
                  <span style="color: var(--color-text-muted);"> ]{gi < STACK.length - 1 ? ',' : ''}</span>
                </div>
              ))}
              <span style="color: #e3b341;">{'}'}</span>
            </div>
          </div>
        </div>

        <!-- Right (5 cols): terminal (fills full height) -->
        <div class="lg:col-span-5">
          <div
            class="rounded-lg overflow-hidden card-elevated h-full"
            style="background-color: var(--color-card-bg); border: 1px solid var(--color-border);"
          >
            <!-- Terminal header -->
            <div
              class="flex items-center gap-2 px-4 py-2.5"
              style="border-bottom: 1px solid var(--color-border); background-color: var(--color-bg-panel);"
            >
              <i class="ti ti-terminal-2 text-sm" style="color: #3fb950;"></i>
              <span class="font-mono text-xs" style="color: var(--color-text-muted);" x-text="t.stack_terminal_header">bash - kelvin@macbook</span>
            </div>

            <!-- Terminal body -->
            <div class="p-4 font-mono text-xs leading-relaxed">
              <!-- Command -->
              <div class="flex items-center gap-1 flex-wrap">
                <span style="color: #3fb950;">~</span>
                <span style="color: var(--color-accent);"> info</span>
                <span style="color: var(--color-text-muted);"> --tech </span>
                <span style="color: #e3b341;">"</span><span style="color: #e3b341;" x-text="activeTech">PHP</span><span style="color: #e3b341;">"</span>
              </div>

              <!-- Output -->
              <div
                class="mt-3 pl-3"
                style="border-left: 2px solid var(--color-border);"
              >
                <div class="flex items-center gap-2 mb-1">
                  <span style="color: var(--color-accent);">·</span>
                  <span class="font-bold" style="color: var(--color-text-primary);" x-text="activeTech">PHP</span>
                </div>
                <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);" x-text="getTechDesc(activeTech)">Linguagem principal de todos os projectos.</p>
              </div>

              <!-- Done line -->
              <div class="mt-3 flex items-center gap-1.5">
                <i class="ti ti-check text-xs" style="color: #3fb950;"></i>
                <span style="color: var(--color-text-muted);" x-text="t.stack_process_done">Process completed with code 0</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

