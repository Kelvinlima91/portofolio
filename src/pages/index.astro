---
import Layout from '../layouts/Layout.astro';

const navLinks = [
  { key: 'nav_about',     href: '#sobre',     pt: 'Sobre',     en: 'About'    },
  { key: 'nav_projects',  href: '#projetos',  pt: 'Projetos',  en: 'Projects' },
  { key: 'nav_education', href: '#educacao',  pt: 'Educação',  en: 'Education'},
  { key: 'nav_contact',   href: '#contacto',  pt: 'Contacto',  en: 'Contact'  },
];

interface Badge {
  label: string;
  color: string;
  icon: string;
  side: 'left' | 'right';
  posClass: string;
  delay: number;
}

const badges: Badge[] = [
  { label: 'Laravel',   color: '#fb923c', icon: 'ti-brand-laravel',  side: 'left',  posClass: 'top-[8%]   -left-28',  delay: 400  },
  { label: 'Alpine.js', color: '#a78bfa', icon: 'ti-bolt',           side: 'right', posClass: 'top-[8%]   -right-28', delay: 700  },
  { label: 'Tailwind',  color: '#60a5fa', icon: 'ti-brand-tailwind', side: 'left',  posClass: 'top-[42%]  -left-32',  delay: 1000 },
  { label: 'Pest PHP',  color: '#22c55e', icon: 'ti-test-pipe',      side: 'right', posClass: 'top-[42%]  -right-32', delay: 1300 },
  { label: 'Vite',      color: '#f59e0b', icon: 'ti-brand-vite',     side: 'left',  posClass: 'bottom-[8%] -left-28', delay: 1600 },
  { label: 'Git',       color: '#f05032', icon: 'ti-brand-git',      side: 'right', posClass: 'bottom-[8%] -right-28',delay: 1900 },
];
---

<Layout>
  <!-- ═══════════════════════════════════════════
       NAV
  ═══════════════════════════════════════════ -->
  <header
    class="fixed top-0 inset-x-0 z-50 border-b"
    style="background-color: rgba(8,11,18,0.75); backdrop-filter: blur(12px); border-color: var(--color-border);"
  >
    <nav
      class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between"
      aria-label="Primary navigation"
    >
      <!-- Logo -->
      <a
        href="/"
        class="font-serif font-semibold text-lg tracking-tight"
        style="color: var(--color-text-primary);"
      >
        kelvinlima.dev
      </a>

      <!-- Right side -->
      <div class="flex items-center gap-6">
        <!-- Anchor links (hidden on mobile, shown md+) -->
        <ul class="hidden md:flex items-center gap-6 list-none m-0 p-0">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-200"
                style="color: var(--color-text-muted);"
                onmouseover="this.style.color='var(--color-text-primary)'"
                onmouseout="this.style.color='var(--color-text-muted)'"
                x-text={`lang === 'pt' ? '${link.pt}' : '${link.en}'`}
              >
                {link.pt}
              </a>
            </li>
          ))}
        </ul>

        <!-- PT / EN toggle -->
        <div
          class="flex items-center rounded-full p-0.5 text-xs font-mono"
          style="background-color: var(--color-bg-panel); border: 1px solid var(--color-border);"
        >
          <button
            @click="toggleLang()"
            class="px-2.5 py-1 rounded-full transition-all duration-200 cursor-pointer"
            :class="lang === 'pt'
              ? 'text-white'
              : 'text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]'"
            :style="lang === 'pt'
              ? 'border: 1px solid var(--color-accent); color: var(--color-accent);'
              : 'border: 1px solid transparent;'"
            aria-label="Switch to Portuguese"
          >
            PT
          </button>
          <button
            @click="toggleLang()"
            class="px-2.5 py-1 rounded-full transition-all duration-200 cursor-pointer"
            :class="lang === 'en'
              ? 'text-white'
              : 'text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]'"
            :style="lang === 'en'
              ? 'border: 1px solid var(--color-accent); color: var(--color-accent);'
              : 'border: 1px solid transparent;'"
            aria-label="Switch to English"
          >
            EN
          </button>
        </div>

        <!-- Dark / Light toggle -->
        <button
          @click="toggleDark()"
          class="w-8 h-8 flex items-center justify-center rounded-full transition-colors duration-200 cursor-pointer"
          style="border: 1px solid var(--color-border); color: var(--color-text-muted);"
          aria-label="Toggle dark mode"
        >
          <i
            class="ti text-base leading-none"
            :class="dark ? 'ti-sun' : 'ti-moon'"
          ></i>
        </button>
      </div>
    </nav>
  </header>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section
    id="sobre"
    class="min-h-screen flex items-center pt-16"
    aria-label="Hero"
  >
    <div class="max-w-6xl mx-auto px-6 w-full py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- ── LEFT: text ── -->
      <div class="flex flex-col justify-center gap-6">

        <!-- Availability badge -->
        <div class="flex items-center gap-2 w-fit">
          <span
            class="w-2 h-2 rounded-full"
            style="background-color: var(--color-accent-green);"
          ></span>
          <span
            class="text-sm font-mono"
            style="color: var(--color-accent-green);"
            x-text="t.available"
          >
            Disponível para projectos
          </span>
        </div>

        <!-- H1 -->
        <h1 class="font-serif leading-none tracking-tight" style="font-size: clamp(3rem, 6vw, 4.5rem);">
          <span class="block" style="color: var(--color-text-primary);">Kelvin</span>
          <span
            class="block italic"
            style="color: var(--color-accent);"
          >Lima.</span>
        </h1>

        <!-- Tagline -->
        <p
          class="text-base max-w-sm leading-relaxed"
          style="color: var(--color-text-muted);"
          x-text="t.hero_tagline"
        >
          Software developer a construir produtos digitais para Cabo Verde
        </p>

        <!-- CTAs -->
        <div class="flex items-center gap-3 flex-wrap">
          <a
            href="#projetos"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-opacity duration-200 hover:opacity-90"
            style="background-color: var(--color-accent); color: #fff;"
            x-text="t.cta_projects"
          >
            Ver projectos
          </a>
          <a
            href="/cv.pdf"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200"
            style="border: 1px solid var(--color-border-strong); color: var(--color-text-primary);"
            onmouseover="this.style.borderColor='var(--color-accent)'; this.style.color='var(--color-accent)'"
            onmouseout="this.style.borderColor='var(--color-border-strong)'; this.style.color='var(--color-text-primary)'"
          >
            <i class="ti ti-file-cv text-base"></i>
            CV
          </a>
        </div>

        <!-- Tech tags -->
        <div class="flex flex-wrap gap-2 pt-2">
          {['Laravel 12', 'Tailwind v4', 'Alpine.js', 'Pest PHP'].map((tag) => (
            <span
              class="inline-flex items-center px-3 py-1 rounded-full text-xs font-mono"
              style="background-color: var(--color-bg-panel); border: 1px solid var(--color-border); color: var(--color-text-muted);"
            >
              {tag}
            </span>
          ))}
          <span
            class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-mono"
            style="background-color: var(--color-bg-panel); border: 1px solid var(--color-border); color: var(--color-text-muted);"
          >
            <i class="ti ti-map-pin text-xs" style="color: var(--color-accent);"></i>
            Mindelo, CV
          </span>
        </div>
      </div>

      <!-- ── RIGHT: monitor illustration ── -->
      <div class="relative flex items-center justify-center py-16 lg:py-8">

        <!-- Monitor wrapper (badges are positioned relative to this) -->
        <div class="relative" style="width: 380px;">

          <!-- Tech badges (absolutely positioned around monitor) -->
          {badges.map((b) => (
            <div
              class={`badge-${b.side} absolute ${b.posClass} z-10 flex items-center gap-2 px-3 py-2 rounded-xl text-xs font-mono whitespace-nowrap select-none`}
              style={`background-color: var(--color-bg-card); border: 1px solid ${b.color}33; color: ${b.color}; animation-delay: ${b.delay}ms;`}
            >
              <i class={`ti ${b.icon} text-sm`}></i>
              {b.label}
            </div>
          ))}

          <!-- Monitor frame -->
          <div
            class="relative rounded-xl overflow-hidden shadow-2xl"
            style="border: 2px solid var(--color-border-strong);"
          >
            <!-- Title bar -->
            <div
              class="flex items-center gap-1.5 px-4 py-3"
              style="background-color: #0d1520; border-bottom: 1px solid var(--color-border);"
            >
              <span class="w-3 h-3 rounded-full" style="background: #ff5f56;"></span>
              <span class="w-3 h-3 rounded-full" style="background: #ffbd2e;"></span>
              <span class="w-3 h-3 rounded-full" style="background: #27c93f;"></span>
            </div>

            <!-- Screen -->
            <div
              class="px-8 py-10 flex flex-col items-center justify-center text-center gap-4"
              style="background: linear-gradient(135deg, #0a1628, #0d1f3c); min-height: 220px; position: relative; overflow: hidden;"
            >
              <!-- Radial glow -->
              <div
                style="position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(14,165,233,0.12) 0%, transparent 70%); pointer-events: none;"
              ></div>

              <!-- Icon -->
              <i
                class="ti ti-bulb text-3xl relative z-10"
                style="color: var(--color-accent-amber);"
              ></i>

              <!-- Main text with cursor -->
              <p
                class="font-mono text-sm font-medium relative z-10 leading-relaxed"
                style="color: var(--color-accent);"
              >
                Work smart, not hard.<span class="cursor-blink">▌</span>
              </p>

              <!-- Subtitle -->
              <p
                class="font-mono text-xs relative z-10"
                style="color: var(--color-text-subtle);"
              >
                — every developer ever
              </p>
            </div>
          </div>

          <!-- Monitor stand -->
          <div class="flex flex-col items-center">
            <!-- Neck -->
            <div
              class="w-12 h-6"
              style="background: linear-gradient(to bottom, #1a2035, #151c2e);"
            ></div>
            <!-- Base -->
            <div
              class="h-3 rounded-b-full"
              style="width: 120px; background: linear-gradient(to bottom, #151c2e, #0f1525);"
            ></div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROJECTS
  ═══════════════════════════════════════════ -->
  <section
    id="projetos"
    class="py-24 fade-in"
    aria-labelledby="projects-heading"
  >
    <div class="max-w-6xl mx-auto px-6">

      <!-- Section heading -->
      <h2
        id="projects-heading"
        class="font-serif text-2xl font-semibold mb-12"
        style="color: var(--color-text-primary);"
        x-text="t.section_projects"
      >
        Projectos seleccionados
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <!-- ── Featured card: O Menu CV ── -->
        <article
          class="project-card md:col-span-2 rounded-xl p-5 flex flex-col gap-5 transition-colors duration-300 cursor-default"
          style="background-color: var(--color-bg-card); border: 0.5px solid var(--color-border);"
        >
          <!-- Top row: tag + arrow -->
          <div class="flex items-start justify-between gap-4">
            <div class="flex flex-col gap-3">
              <!-- Tag -->
              <span
                class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-mono w-fit"
                style="background-color: rgba(14,165,233,0.1); color: var(--color-accent); border: 1px solid rgba(14,165,233,0.25);"
                x-text="t.featured_tag"
              >
                Destaque
              </span>

              <!-- Title -->
              <h3
                class="font-serif text-xl font-semibold"
                style="color: var(--color-text-primary);"
              >
                O Menu CV
              </h3>
            </div>

            <!-- Arrow link -->
            <a
              href="#"
              class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-lg transition-colors duration-200"
              style="border: 1px solid var(--color-border); color: var(--color-text-muted);"
              aria-label="Ver projecto O Menu CV no GitHub"
            >
              <i class="ti ti-arrow-up-right text-base"></i>
            </a>
          </div>

          <!-- Description -->
          <p
            class="text-sm leading-relaxed max-w-2xl"
            style="color: var(--color-text-muted);"
            x-text="t.proj_omenu_desc"
          >
            Plataforma de descoberta de restaurantes e pré-encomenda de refeições para Cabo Verde. 107 testes, dashboard com KPIs em tempo real, sistema Menu da Semana.
          </p>

          <!-- Stack chips -->
          <div class="flex flex-wrap gap-2">
            {['Laravel 12', 'Alpine.js', 'Tailwind v4', 'Pest PHP'].map((chip) => (
              <span
                class="px-3 py-1 rounded-full text-xs font-mono"
                style="background-color: var(--color-bg-panel); border: 1px solid var(--color-border); color: var(--color-text-subtle);"
              >
                {chip}
              </span>
            ))}
          </div>
        </article>

        <!-- ── Secondary card: Reklama ── -->
        <article
          class="project-card rounded-xl p-5 flex flex-col gap-4 transition-colors duration-300 cursor-default"
          style="background-color: var(--color-bg-card); border: 0.5px solid var(--color-border);"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex flex-col gap-3">
              <span
                class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-mono w-fit"
                style="background-color: rgba(245,158,11,0.1); color: var(--color-accent-amber); border: 1px solid rgba(245,158,11,0.25);"
                x-text="t.proj_reklama_tag"
              >
                Regulação
              </span>
              <h3
                class="font-serif text-lg font-semibold"
                style="color: var(--color-text-primary);"
              >
                Reklama
              </h3>
            </div>
            <a
              href="#"
              class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-lg transition-colors duration-200"
              style="border: 1px solid var(--color-border); color: var(--color-text-muted);"
              aria-label="Ver projecto Reklama no GitHub"
            >
              <i class="ti ti-arrow-up-right text-base"></i>
            </a>
          </div>

          <p
            class="text-sm leading-relaxed"
            style="color: var(--color-text-muted);"
            x-text="t.proj_reklama_desc"
          >
            Portal eletrónico de reclamações de consumidores com dashboards para utilizadores, empresas e reguladores.
          </p>

          <div class="flex flex-wrap gap-2 mt-auto">
            {['Laravel', 'AJAX', 'MySQL'].map((chip) => (
              <span
                class="px-3 py-1 rounded-full text-xs font-mono"
                style="background-color: var(--color-bg-panel); border: 1px solid var(--color-border); color: var(--color-text-subtle);"
              >
                {chip}
              </span>
            ))}
          </div>
        </article>

        <!-- ── Secondary card: Portal de Vagas CV ── -->
        <article
          class="project-card rounded-xl p-5 flex flex-col gap-4 transition-colors duration-300 cursor-default"
          style="background-color: var(--color-bg-card); border: 0.5px solid var(--color-border);"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex flex-col gap-3">
              <span
                class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-mono w-fit"
                style="background-color: rgba(34,197,94,0.1); color: var(--color-accent-green); border: 1px solid rgba(34,197,94,0.25);"
                x-text="t.proj_vagas_tag"
              >
                Emprego
              </span>
              <h3
                class="font-serif text-lg font-semibold"
                style="color: var(--color-text-primary);"
              >
                Portal de Vagas CV
              </h3>
            </div>
            <a
              href="#"
              class="flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-lg transition-colors duration-200"
              style="border: 1px solid var(--color-border); color: var(--color-text-muted);"
              aria-label="Ver projecto Portal de Vagas CV no GitHub"
            >
              <i class="ti ti-arrow-up-right text-base"></i>
            </a>
          </div>

          <p
            class="text-sm leading-relaxed"
            style="color: var(--color-text-muted);"
            x-text="t.proj_vagas_desc"
          >
            Portal de emprego com três perfis (Candidato, Empresa, Admin) e ciclo de moderação de vagas.
          </p>

          <div class="flex flex-wrap gap-2 mt-auto">
            {['Laravel 12', 'Tailwind v4'].map((chip) => (
              <span
                class="px-3 py-1 rounded-full text-xs font-mono"
                style="background-color: var(--color-bg-panel); border: 1px solid var(--color-border); color: var(--color-text-subtle);"
              >
                {chip}
              </span>
            ))}
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       EDUCATION
  ═══════════════════════════════════════════ -->
  <section
    id="educacao"
    class="py-24 fade-in"
    aria-labelledby="education-heading"
  >
    <div class="max-w-4xl mx-auto px-6">

      <!-- Section heading -->
      <h2
        id="education-heading"
        class="font-serif text-2xl font-semibold mb-16 text-center"
        style="color: var(--color-text-primary);"
        x-text="t.section_education"
      >
        Educação
      </h2>

      <!-- Timeline -->
      <div class="relative">

        <!-- Center line -->
        <div
          class="absolute top-0 bottom-0 w-0.5 -translate-x-1/2"
          style="left: 50%; background: linear-gradient(to bottom, #0ea5e9, rgba(14,165,233,0.12));"
          aria-hidden="true"
        ></div>

        <!-- ── Node 1: Oct 2020 — LEFT ── -->
        <div class="grid items-center mb-9" style="grid-template-columns: 1fr 52px 1fr;">
          <!-- Left content -->
          <div class="text-right pr-6">
            <p class="text-xs font-mono mb-1" style="color: #0ea5e9;">Out 2020</p>
            <h3
              class="font-serif text-base font-semibold mb-1"
              style="color: var(--color-text-primary);"
              x-text="t.edu_1_title"
            >Início da Licenciatura</h3>
            <p
              class="text-xs leading-relaxed"
              style="color: var(--color-text-muted);"
              x-text="t.edu_1_sub"
            >Engenharia de Sistemas e Informática — Universidade Jean Piaget de Cabo Verde, Pólo do Mindelo</p>
          </div>
          <!-- Node -->
          <div class="flex justify-center">
            <div
              class="w-11 h-11 rounded-full flex items-center justify-center relative z-10"
              style="background: #0a1628; border: 2px solid #0ea5e9;"
            >
              <i class="ti ti-flag" style="color: #0ea5e9; font-size: 20px;"></i>
            </div>
          </div>
          <!-- Right: empty -->
          <div></div>
        </div>

        <!-- ── Node 2: 2021 — RIGHT ── -->
        <div class="grid items-center mb-9" style="grid-template-columns: 1fr 52px 1fr;">
          <!-- Left: empty -->
          <div></div>
          <!-- Node -->
          <div class="flex justify-center">
            <div
              class="w-11 h-11 rounded-full flex items-center justify-center relative z-10"
              style="background: #0f0a1f; border: 2px solid #a78bfa;"
            >
              <i class="ti ti-book" style="color: #a78bfa; font-size: 20px;"></i>
            </div>
          </div>
          <!-- Right content -->
          <div class="pl-6">
            <p class="text-xs font-mono mb-1" style="color: #a78bfa;">2021</p>
            <h3
              class="font-serif text-base font-semibold mb-1"
              style="color: var(--color-text-primary);"
              x-text="t.edu_2_title"
            >Fundamentos</h3>
            <p
              class="text-xs leading-relaxed"
              style="color: var(--color-text-muted);"
              x-text="t.edu_2_sub"
            >Algoritmos, bases de dados, POO, redes de computadores.</p>
          </div>
        </div>

        <!-- ── Node 3: 2022 — LEFT ── -->
        <div class="grid items-center mb-9" style="grid-template-columns: 1fr 52px 1fr;">
          <!-- Left content -->
          <div class="text-right pr-6">
            <p class="text-xs font-mono mb-1" style="color: #f59e0b;">2022</p>
            <h3
              class="font-serif text-base font-semibold mb-1"
              style="color: var(--color-text-primary);"
              x-text="t.edu_3_title"
            >Desenvolvimento web</h3>
            <p
              class="text-xs leading-relaxed"
              style="color: var(--color-text-muted);"
              x-text="t.edu_3_sub"
            >Primeiros projectos Laravel, foco em produtos para o mercado cabo-verdiano.</p>
          </div>
          <!-- Node -->
          <div class="flex justify-center">
            <div
              class="w-11 h-11 rounded-full flex items-center justify-center relative z-10"
              style="background: #1a1204; border: 2px solid #f59e0b;"
            >
              <i class="ti ti-code" style="color: #f59e0b; font-size: 20px;"></i>
            </div>
          </div>
          <!-- Right: empty -->
          <div></div>
        </div>

        <!-- ── Node 4: 2023 — RIGHT ── -->
        <div class="grid items-center mb-9" style="grid-template-columns: 1fr 52px 1fr;">
          <!-- Left: empty -->
          <div></div>
          <!-- Node -->
          <div class="flex justify-center">
            <div
              class="w-11 h-11 rounded-full flex items-center justify-center relative z-10"
              style="background: #041a10; border: 2px solid #22c55e;"
            >
              <i class="ti ti-rocket" style="color: #22c55e; font-size: 20px;"></i>
            </div>
          </div>
          <!-- Right content -->
          <div class="pl-6">
            <p class="text-xs font-mono mb-1" style="color: #22c55e;">2023</p>
            <h3
              class="font-serif text-base font-semibold mb-1"
              style="color: var(--color-text-primary);"
              x-text="t.edu_4_title"
            >Projecto final</h3>
            <p
              class="text-xs leading-relaxed"
              style="color: var(--color-text-muted);"
              x-text="t.edu_4_sub"
            >Desenvolvimento da plataforma lroOnline (Reklama) como TCC.</p>
          </div>
        </div>

        <!-- ── Node 5: Jun 2024 — LEFT ── -->
        <div class="grid items-center" style="grid-template-columns: 1fr 52px 1fr;">
          <!-- Left content -->
          <div class="text-right pr-6">
            <p class="text-xs font-mono mb-1" style="color: #0ea5e9;">Jun 2024</p>
            <h3
