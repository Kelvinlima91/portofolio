        >
          <i class="ti ti-bolt" style="font-size: 18px; color: #0ea5e9;"></i>
          <span style="font-size: 13px; color: #94a3b8; font-weight: 500;">Alpine.js</span>
          <span class="font-mono" style="font-size: 11px; color: #374151;" x-text="t.stack_alpine_sub">Interactividade</span>
        </div>

        <!-- Pest PHP -->
        <div
          class="flex flex-col"
          style="gap: 6px; background: #0c0f1a; border: 0.5px solid #1a1e2e; border-radius: 8px; padding: 14px 16px;"
        >
          <i class="ti ti-test-pipe" style="font-size: 18px; color: #0ea5e9;"></i>
