        </div>

      </div>

      <!-- Footer row -->
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-6 pt-6" style="border-top: 1px solid var(--color-border);">
        <!-- Status pill -->
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-mono"
          style="background-color: rgba(63,185,80,0.08); border: 1px solid rgba(63,185,80,0.25);"
        >
          <div class="relative w-2 h-2 flex-shrink-0">
            <span class="absolute inset-0 rounded-full animate-ping" style="background-color: #3fb950; opacity: 0.6;"></span>
            <span class="relative block w-2 h-2 rounded-full" style="background-color: #3fb950;"></span>
          </div>
          <span style="color: #3fb950;" x-text="t.contact_status_ok">All systems normal</span>
        </div>

        <!-- Copyright -->
        <p class="text-xs" style="color: var(--color-text-subtle);">
          &copy; {new Date().getFullYear()} Kelvin Lima. Made with pure craftsmanship.
        </p>
      </div>

    </div>
  </section>

</Layout>

<script>
  import Alpine from 'alpinejs';
  import { PROJECTS, EDUCATION, STACK, TECH_DETAILS } from '../data/portfolio.js';

  document.addEventListener('alpine:init', () => {

    Alpine.data('projectsSection', () => ({
      projects: PROJECTS,
      search: '',
      langFilter: 'all',
      sortBy: 'stars',

      get filteredProjects() {
        let result = [...this.projects];
        if (this.search) {
          const q = this.search.toLowerCase();
          result = result.filter((p) =>
            p.name.toLowerCase().includes(q) ||
            p.descriptionPt.toLowerCase().includes(q) ||
            p.descriptionEn.toLowerCase().includes(q)
          );
        }
        if (this.langFilter !== 'all') {
          result = result.filter((p) => p.language === this.langFilter);
        }
        if (this.sortBy === 'stars') {
          result.sort((a, b) => b.stars - a.stars);
        } else if (this.sortBy === 'name') {
          result.sort((a, b) => a.name.localeCompare(b.name));
        }
        return result;
      },

      resetFilters() {
        this.search = '';
        this.langFilter = 'all';
      },
    }));

    Alpine.data('educationSection', () => ({
      expandedId: 'piaget-graduation',
      toggle(id: string) {
        this.expandedId = this.expandedId === id ? null : id;
      },
    }));

    Alpine.data('stackSection', () => ({
      activeTech: 'PHP',
      techDetails: TECH_DETAILS,
      getTechDesc(tech: string) {
        const detail = (this.techDetails as Record<string, { pt: string; en: string }>)[tech];
        if (!detail) return 'Technology in the stack.';
        const lang = document.documentElement.lang || 'pt';
        return lang === 'en' ? detail.en : detail.pt;
      },
    }));

    Alpine.data('contactSection', () => ({
      tab: 'write',
      title: '',
      body: '',
      loading: false,

      renderPreview(text: string) {
        if (!text) return '';
        return text
          .split('\n')
          .map((line) => {
            if (line.startsWith('### ')) {
              return `<h4 style="font-weight:700;color:var(--color-text-primary);margin:8px 0 4px;">${line.slice(4)}</h4>`;
            }
            if (line.startsWith('- ')) {
              return `<div style="display:flex;gap:6px;align-items:flex-start;padding:2px 0;"><span style="color:var(--color-accent);flex-shrink:0;">·</span><span style="color:var(--color-text-muted);">${line.slice(2)}</span></div>`;
            }
            if (line === '') {
              return '<br>';
            }
            return `<p style="margin:4px 0;color:var(--color-text-muted);">${line}</p>`;
          })
          .join('');
      },

      submit() {
        if (!this.title.trim()) return;
        this.loading = true;
        const subject = '[GitHub Issue] ' + this.title;
        const mailto =
          'mailto:hello@kelvinlima.dev?subject=' +
          encodeURIComponent(subject) +
          '&body=' +
          encodeURIComponent(this.body);
        setTimeout(() => {
          window.location.href = mailto;
          this.loading = false;
        }, 600);
      },
    }));

  });
</script>
